# 量化数据平台 - 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# 注意: 不要提交包含真实Token的 .env 文件到版本控制!

# ===================
# Tushare API 配置
# ===================
# Tushare Token - 请从 https://tushare.pro 注册获取
# 注册后可在个人主页 -> 接口Token 中查看
TUSHARE_TOKEN=your_tushare_token_here

# ===================
# 数据库配置
# ===================
# PostgreSQL 配置 (Docker中默认)
DB_HOST=postgres
DB_PORT=5432
DB_USER=quant_user
DB_PASSWORD=quant_pass
DB_NAME=quant_platform

# 完整数据库连接URL
DATABASE_URL=postgresql://quant_user:quant_pass@postgres:5432/quant_platform

# ===================
# 应用配置
# ===================
# 环境: development | production
ENV=development

# 后端配置
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# 前端配置
FRONTEND_PORT=3000

# ===================
# 可选配置
# ===================
# 日志级别
LOG_LEVEL=INFO

# 缓存配置
CACHE_ENABLED=true
CACHE_TTL=300

# 数据源配置
AKSHARE_START_DATE=20240101
AKSHARE_ADJUST=qfq
